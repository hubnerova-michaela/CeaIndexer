<Window x:Class="CeaIndexer.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CeaIndexer"
        xmlns:p="clr-namespace:CeaIndexer.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.FirstRun_Title}" Height="580" Width="692"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F9F9F9">

    <Border Padding="25">
        <StackPanel>
            <TextBlock Text="{x:Static p:Resources.FirstRun_Header}" FontSize="26" FontWeight="Bold" Margin="0,0,0,10" Foreground="#222"/>
            <TextBlock Text="{x:Static p:Resources.FirstRun_Description}"
                       TextWrapping="Wrap" FontSize="14" Margin="0,0,0,20" Foreground="#555"/>

            <TextBlock Text="{x:Static p:Resources.FirstRun_ErxPath}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtErxPath" Grid.Column="0" Margin="0,0,10,0" Padding="6" FontSize="14" IsReadOnly="True" Background="White"/>
                <Button x:Name="BtnBrowseErx" Grid.Column="1" Content="{x:Static p:Resources.FirstRun_Browse}" Padding="15,5" FontSize="14" Cursor="Hand" Click="BtnBrowseErx_Click"/>
            </Grid>

            <TextBlock Text="{x:Static p:Resources.FirstRun_Folders}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="LstFolders" Grid.Column="0" Margin="0,0,10,0" Height="80" Background="White" FontSize="13"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button x:Name="BtnAddFolder" Content="{x:Static p:Resources.FirstRun_AddFolder}" Padding="15,5" Margin="0,0,0,5" FontSize="14" Cursor="Hand" Click="BtnAddFolder_Click"/>
                    <Button x:Name="BtnRemoveFolder" Content="{x:Static p:Resources.FirstRun_RemoveFolder}" Padding="15,5" FontSize="14" Cursor="Hand" Click="BtnRemoveFolder_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Static p:Resources.FirstRun_Language}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbLanguage" Margin="0,0,0,25" Padding="6" FontSize="14" SelectedIndex="0">
                <ComboBoxItem Content="{x:Static p:Resources.FirstRun_LangCs}" Tag="cs-CZ"/>
                <ComboBoxItem Content="{x:Static p:Resources.FirstRun_LangEn}" Tag="en-US"/>
            </ComboBox>
            <Button x:Name="BtnSave" Content="{x:Static p:Resources.FirstRun_Save}" 
                    FontSize="16" FontWeight="Bold" Padding="12" 
                    Background="#0078D7" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Border>
</Window>
