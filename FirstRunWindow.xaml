<Window x:Class="CeaIndexer.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CeaIndexer"
        xmlns:p="clr-namespace:CeaIndexer.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.FirstRun_Title}" Height="580" Width="692"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="MainContainer" Background="{DynamicResource WindowBgBrush}" Margin="15" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{x:Static p:Resources.FirstRun_Title}" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="13"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" Click="BtnClose_Click" ToolTip="Zavřít"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="25,10,25,25">
                <StackPanel>
                    <TextBlock Text="{x:Static p:Resources.FirstRun_Header}" FontSize="26" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{x:Static p:Resources.FirstRun_Description}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Text="{x:Static p:Resources.FirstRun_ErxPath}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtErxPath" Grid.Column="0" Margin="0,0,10,0" Padding="6" FontSize="14" IsReadOnly="True" 
                                 Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                        <Button x:Name="BtnBrowseErx" Grid.Column="1" Style="{StaticResource FlatButton}" Content="{x:Static p:Resources.FirstRun_Browse}" Padding="15,5" FontSize="14" Click="BtnBrowseErx_Click"/>
                    </Grid>

                    <TextBlock Text="{x:Static p:Resources.FirstRun_Folders}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="LstFolders" Grid.Column="0" Margin="0,0,10,0" Height="80" 
                                 Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" FontSize="13"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                            <Button x:Name="BtnAddFolder" Style="{StaticResource FlatButton}" Content="{x:Static p:Resources.FirstRun_AddFolder}" Padding="15,5" Margin="0,0,0,5" FontSize="14" Click="BtnAddFolder_Click"/>
                            <Button x:Name="BtnRemoveFolder" Style="{StaticResource FlatButton}" Content="{x:Static p:Resources.FirstRun_RemoveFolder}" Padding="15,5" FontSize="14" Click="BtnRemoveFolder_Click"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{x:Static p:Resources.FirstRun_Language}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox x:Name="CmbLanguage" Margin="0,0,0,25" Padding="6" FontSize="14" SelectedIndex="0" 
                              Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}">
                        <ComboBoxItem Content="{x:Static p:Resources.FirstRun_LangCs}" Tag="cs-CZ"/>
                        <ComboBoxItem Content="{x:Static p:Resources.FirstRun_LangEn}" Tag="en-US"/>
                    </ComboBox>

                    <Button x:Name="BtnSave" Style="{StaticResource AccentButton}" Content="{x:Static p:Resources.FirstRun_Save}" 
                            FontSize="16" FontWeight="Bold" Padding="12" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>