<Window x:Class="CeaIndexer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CEA Indexer" Height="750" Width="1200">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,5" HorizontalAlignment="Right">
            <TextBlock x:Name="LanguageLabel" VerticalAlignment="Center" Text="Language:" Margin="0,0,5,0"/>
            <ComboBox x:Name="LanguageComboBox" Width="100" SelectionChanged="LanguageComboBox_SelectionChanged">
                <ComboBoxItem Content="English" Tag="en"/>
                <ComboBoxItem x:Name="CzechLanguageItem" Content="" Tag="cs"/>
            </ComboBox>
            <Button x:Name="WatchlistButton" Content="Manage Watchlist" Width="140" Margin="15,0,0,0" Click="WatchlistButton_Click" Background="#0078D7" Foreground="White"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,5">
            <TextBlock x:Name="ErxPathLabel" VerticalAlignment="Center" Text="Path to erx.exe:" Margin="0,0,5,0" Width="100"/>
            <TextBox x:Name="ErxPathTextBox" Width="400" Margin="0,0,5,0" TextChanged="ErxPathTextBox_TextChanged"/>
            <Button x:Name="BrowseErxButton" Content="Browse..." Width="80" Click="BrowseErx_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,15">
            <TextBlock x:Name="CeaFolderLabel" VerticalAlignment="Center" Text="CEA Folder:" Margin="0,0,5,0" Width="100"/>
            <TextBox x:Name="FolderTextBox" Width="400" Margin="0,0,5,0" TextChanged="FolderTextBox_TextChanged"/>
            <Button x:Name="BrowseFolderButton" Content="Browse..." Width="80" Click="BrowseFolder_Click"/>
            <Button x:Name="LoadFilesButton" Content="Load Files" Width="110" Margin="15,0,0,0" Click="LoadFiles_Click" FontWeight="Bold"/>
        </StackPanel>

        <WrapPanel Grid.Row="3" Margin="0,0,0,10" Orientation="Horizontal">
            <Button x:Name="RefreshButton" Content="Refresh" Width="100" Margin="0,0,15,0" Click="RefreshDb_Click"/>

            <TextBlock x:Name="QuantityLabel" VerticalAlignment="Center" Text="Quantity:" Margin="0,0,5,0"/>
            
            <!-- Combined search + dropdown (ComboBox with IsEditable=True) -->
            <ComboBox x:Name="SearchComboBox" Width="200" Margin="0,0,10,0" IsEditable="True"/>

            <TextBlock x:Name="OperatorLabel" VerticalAlignment="Center" Text="Operator:" Margin="0,0,5,0"/>
            <ComboBox x:Name="OperatorComboBox" Width="60" Margin="0,0,5,0" SelectedIndex="0">
                <ComboBoxItem Content="---"/>
                <ComboBoxItem Content=">"/>
                <ComboBoxItem Content="&lt;"/>
                <ComboBoxItem Content="="/>
            </ComboBox>

            <TextBox x:Name="ValueTextBox" Width="80" Margin="0,0,10,0"/>

            <Button x:Name="FilterButton" Content="Filter" Width="80" Click="SearchDb_Click"/>
        </WrapPanel>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <GroupBox x:Name="IndexedFilesGroup" Header="Indexed Files" Grid.Column="0">
                <DataGrid x:Name="DatabaseDataGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          AlternatingRowBackground="#FFF0F0F0"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionChanged="DatabaseDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="36" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="22"
                                            Height="22"
                                            Padding="0"
                                            ToolTip="Open file in external app"
                                            Click="OpenFileExternalButton_Click">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray" Margin="2,0"/>

            <GroupBox x:Name="FileDetailsGroup" Header="File Details (Quantities)" Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="QuantitiesDataGrid" Grid.Row="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#FFF0F0F0"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ArchiveColumn" Header="Archive" Binding="{Binding Archive}" Width="120"/>
                            <DataGridTextColumn x:Name="QuantityNameColumn" Header="Quantity Name" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="LightGray" Margin="0,2"/>

                    <TextBox x:Name="OutputTextBox" Grid.Row="2"
                             FontFamily="Consolas"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Background="#FAFAFA"
                             Foreground="#333"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
            </StatusBarItem>

            <StatusBarItem x:Name="ActivityStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar x:Name="PhaseProgressBar" Width="180" Height="14" Minimum="0" Maximum="100" Value="0" Margin="0,0,12,0"/>
                    <TextBlock x:Name="CurrentFileStatusTextBlock" Text="File: -" Margin="0,0,12,0"/>
                    <TextBlock x:Name="LastFileResultTextBlock" Text="Last result: -"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
