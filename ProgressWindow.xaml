<Window x:Class="CeaIndexer.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:p="clr-namespace:CeaIndexer.Properties"
        xmlns:local="clr-namespace:CeaIndexer"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Progress_Title}" Height="550" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F3F4"
        FontFamily="Segoe UI">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtGlobalStatus" Text="{x:Static p:Resources.Progress_Preparing}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
            <ProgressBar x:Name="GlobalProgressBar" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#27AE60" Background="#E5E7E9" BorderThickness="0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Progress_FileQueue}" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15"/>

                    <ListBox Grid.Row="1" x:Name="LstFiles" ItemsSource="{Binding FileItems}" SelectionChanged="LstFiles_SelectionChanged" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="{Binding StatusIcon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="14" Foreground="#2C3E50" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="{x:Static p:Resources.Progress_CurrentlyProcessing}" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding CurrentFileName}" FontSize="18" FontWeight="Bold" Foreground="#2980B9" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding CurrentFileStats}" FontSize="14" Foreground="#27AE60" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding CurrentMeasurePoints}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding StatusIcon}" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="14" Foreground="#34495E"/>
                                    <TextBlock Text="{Binding DeviceType, StringFormat=' ({0})'}" FontSize="13" Foreground="#95A5A6"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
