<UserControl x:Class="CeaIndexer.Views.ConditionBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CeaIndexer.Views"
             xmlns:models="clr-namespace:CeaIndexer.FilterModels"
             mc:Ignorable="d" 
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteRuleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E81123"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEAEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="Tvůrce dotazu" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>

                <Button Style="{StaticResource FlatButton}" Margin="20,0,0,0" Padding="15,7" Click="BtnAddRule_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Přidat podmínku" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SuccessButton}" Margin="10,0,0,0" Padding="15,7" Click="BtnSearch_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Hledat" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                <ItemsControl x:Name="RuleItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ConditionRule}">
                            <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,5,8" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0" Margin="0,0,10,0" SelectedItem="{Binding Category, Mode=TwoWay}" ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailableCategories}"/>

                                    <ComboBox Grid.Column="1" Margin="0,0,10,0" 
                                        ItemsSource="{Binding AvailableProperties}" 
                                        DisplayMemberPath="DisplayName" 
                                        SelectedValuePath="Key"
                                        SelectedValue="{Binding TargetProperty, Mode=TwoWay}"/>

                                    <ComboBox Grid.Column="2" Margin="0,0,10,0" SelectedItem="{Binding Operator, Mode=TwoWay}" ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailableOperators}"/>

                                    <TextBox Grid.Column="3" Margin="0,0,10,0" Text="{Binding Value, Mode=TwoWay}" VerticalContentAlignment="Center" Padding="5"/>

                                    <Button Grid.Column="4" Style="{StaticResource DeleteRuleButton}" Width="30" ToolTip="Odebrat podmínku" Click="BtnDeleteRule_Click">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE179;" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="Výběr veličin pro hloubkovou analýzu" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <TreeView Grid.Row="3" 
                      ItemsSource="{Binding QuantityTree}" 
                      Background="{DynamicResource CardBgBrush}" 
                      BorderBrush="{DynamicResource BorderBrush}" 
                      BorderThickness="1" 
                      Padding="5" 
                      Margin="0,0,5,0">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2,4,2,4">
                            <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="Nalezené soubory" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <DataGrid x:Name="ResultsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" 
                      Background="{DynamicResource CardBgBrush}" 
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                      RowBackground="{DynamicResource CardBgBrush}" 
                      AlternatingRowBackground="{DynamicResource WindowBgBrush}" 
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cesta k souboru" Binding="{Binding}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>