<UserControl x:Class="CeaIndexer.Views.DatabaseExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CeaIndexer.Views"
             mc:Ignorable="d" 
             Background="Transparent"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71C;" FontSize="16" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Filtrování přístrojů" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Zdrojový soubor:" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbFilterFile" Width="180" IsEditable="True" StaysOpenOnEdit="True" KeyUp="Filter_Changed" SelectionChanged="Filter_Changed"
                                  Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Model (Device):" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbFilterDevice" Width="150" IsEditable="True" StaysOpenOnEdit="True" KeyUp="Filter_Changed" SelectionChanged="Filter_Changed"
                                  Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Obsahuje veličinu:" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbFilterQuantity" Width="200" IsEditable="True" StaysOpenOnEdit="True" KeyUp="Filter_Changed" SelectionChanged="Filter_Changed"
                                  Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Hledat v textu (Název, SN):" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtSearch" Width="150" Padding="4,2" TextChanged="Filter_Changed"
                                 Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <Button Style="{StaticResource DangerButton}" Width="130" Height="28" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="BtnClearFilters_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Vymazat filtry" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <TextBlock x:Name="TxtStats" Text="Načítám data..." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" x:Name="GridMeasurePoints" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionChanged="GridMeasurePoints_SelectionChanged"
                  Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" RowHeight="30"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  RowBackground="{DynamicResource CardBgBrush}" AlternatingRowBackground="{DynamicResource WindowBgBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Soubor" Binding="{Binding FileEntry.FileName}" Width="150"/>
                <DataGridTextColumn Header="Název přístroje (Record)" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Model (Device)" Binding="{Binding DeviceType}" Width="150"/>
                <DataGridTextColumn Header="Sériové č." Binding="{Binding SerialNumber}" Width="100"/>
                <DataGridTextColumn Header="Zapojení" Binding="{Binding WiringType}" Width="100"/>
                <DataGridTextColumn Header="U nom [V]" Binding="{Binding Unom}" Width="80"/>
                <DataGridTextColumn Header="Veličin" Binding="{Binding TotalQuantitiesCount}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}" Margin="0,10" Cursor="SizeNS"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" FontSize="14" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Časové intervaly měření (Archivy)" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="GridIntervals" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                              RowBackground="Transparent" AlternatingRowBackground="{DynamicResource WindowBgBrush}"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Archiv" Binding="{Binding ArchiveName}" Width="120"/>
                            <DataGridTextColumn Header="Od" Binding="{Binding StartTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Do" Binding="{Binding EndTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Výpadky" Binding="{Binding MissingPercentage, StringFormat='{}{0} %'}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" FontSize="14" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Zaznamenávané veličiny" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" x:Name="LstQuantities" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>