<UserControl x:Class="CeaIndexer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CeaIndexer.Views"
             xmlns:p="clr-namespace:CeaIndexer.Properties"
             mc:Ignorable="d" 
             Background="#F8F9FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Settings_Title}" FontSize="26" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" MaxWidth="700" HorizontalAlignment="Left" Width="1000">

            <TextBlock Text="{x:Static p:Resources.Settings_ErxPath}" FontWeight="SemiBold" FontSize="15" Foreground="#34495E" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtErxPath" Grid.Column="0" Margin="0,0,10,0" Padding="8" FontSize="14" IsReadOnly="True" Background="White" BorderBrush="#BDC3C7"/>
                <Button x:Name="BtnBrowseErx" Grid.Column="1" Content="{x:Static p:Resources.Btn_Browse}" Padding="15,5" FontSize="14" Cursor="Hand" Background="White" BorderBrush="#BDC3C7" Click="BtnBrowseErx_Click"/>
            </Grid>

            <TextBlock Text="{x:Static p:Resources.Settings_Folders}" FontWeight="SemiBold" FontSize="15" Foreground="#34495E" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="LstFolders" Grid.Column="0" Margin="0,0,10,0" Height="120" Background="White" BorderBrush="#BDC3C7" FontSize="14" Padding="5"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button x:Name="BtnAddFolder" Content="{x:Static p:Resources.Settings_AddFolder}" Padding="15,8" Margin="0,0,0,10" FontSize="14" Cursor="Hand" Background="White" BorderBrush="#BDC3C7" Click="BtnAddFolder_Click"/>
                    <Button x:Name="BtnRemoveFolder" Content="{x:Static p:Resources.Settings_RemoveSelected}" Padding="15,8" FontSize="14" Cursor="Hand" Background="#FFF0F0" Foreground="#E74C3C" BorderBrush="#F5B7B1" Click="BtnRemoveFolder_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Static p:Resources.Settings_Language}" FontWeight="SemiBold" FontSize="15" Foreground="#34495E" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbLanguage" Padding="8" FontSize="14" Width="250" HorizontalAlignment="Left" Background="White" BorderBrush="#BDC3C7">
                <ComboBoxItem Content="{x:Static p:Resources.Lang_Cs}" Tag="cs-CZ"/>
                <ComboBoxItem Content="{x:Static p:Resources.Lang_En}" Tag="en-US"/>
            </ComboBox>

        </StackPanel>

        <Button x:Name="BtnSave" Grid.Row="2" Content="{x:Static p:Resources.Settings_Save}" 
                Margin="0,20,0,0" Padding="20,12" FontSize="16" FontWeight="Bold" 
                Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"
                HorizontalAlignment="Left" MinWidth="180" Click="BtnSave_Click"/>
    </Grid>
</UserControl>
